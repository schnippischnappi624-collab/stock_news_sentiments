{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lookup_key", "symbol", "resolved_url", "notes"],
        "properties": {
          "lookup_key": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "resolved_url": {
            "type": ["string", "null"]
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
